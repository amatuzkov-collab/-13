def sudoku(board: list) -> bool:
    """
    :param board: start board of sudoku
    :return: true if correct, false otherwise
    """
    rows = [set() for _ in range(9)]
    cols = [set() for _ in range(9)]
    boxes = [set() for _ in range(9)]

    for r in range(9):
        for c in range(9):
            value = board[r][c]

            if value == '.':
                continue
            boxes_ind = (r // 3) * 3 + (c // 3)

            if value in rows[r] or value in cols[c] or value in boxes[boxes_ind]:
                return False

            rows[r].add(value)
            cols[c].add(value)
            boxes[boxes_ind].add(value)

    return True
